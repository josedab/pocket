{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "downlevelIteration": true
  },
  "include": [
    "packages/core/src/**/*",
    "packages/react/src/**/*",
    "packages/sync/src/**/*",
    "packages/server/src/**/*",
    "packages/storage-indexeddb/src/**/*",
    "packages/storage-opfs/src/**/*",
    "packages/storage-memory/src/**/*",
    "packages/ai/src/**/*",
    "packages/auth/src/**/*",
    "packages/encryption/src/**/*",
    "packages/permissions/src/**/*",
    "packages/crdt/src/**/*",
    "packages/analytics/src/**/*",
    "packages/devtools/src/**/*",
    "packages/time-travel/src/**/*",
    "packages/plugin-sdk/src/**/*",
    "packages/forms/src/**/*",
    "packages/views/src/**/*",
    "packages/query-builder/src/**/*",
    "packages/vectors/src/**/*",
    "packages/collaboration/src/**/*",
    "packages/presence/src/**/*",
    "packages/graphql-gateway/src/**/*",
    "packages/cloud/src/**/*",
    "packages/cli/src/**/*",
    "packages/codegen/src/**/*",
    "packages/studio/src/**/*",
    "packages/migration/src/**/*",
    "packages/testing/src/**/*",
    "packages/sync-server/src/**/*",
    "packages/mobile/src/**/*",
    "packages/angular/src/**/*",
    "packages/vue/src/**/*",
    "packages/svelte/src/**/*",
    "packages/solid/src/**/*",
    "packages/schema-inference/src/**/*",
    "packages/opentelemetry/src/**/*",
    "packages/compliance/src/**/*",
    "packages/portable-export/src/**/*",
    "packages/cross-tab/src/**/*",
    "packages/pwa/src/**/*",
    "packages/triggers/src/**/*",
    "packages/computed/src/**/*",
    "packages/subscriptions/src/**/*",
    "packages/rls/src/**/*",
    "packages/zod/src/**/*"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"]
}
